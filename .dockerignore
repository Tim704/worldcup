# =============================================================================
# World Cup 2026 Fantasy Hub — Docker build-context exclusions.
#
# Keep build contexts small & reproducible: never ship local dependency trees,
# compiled artifacts, secrets or VCS metadata into an image layer. This file
# applies to every `build:` context in docker-compose.yml.
# =============================================================================

# ---- Version control --------------------------------------------------------
.git
.gitignore
.gitattributes

# ---- Secrets / local env (NEVER bake into an image) -------------------------
.env
**/.env
**/.env.*
!**/.env.example

# ---- Node / frontend --------------------------------------------------------
**/node_modules
frontend/dist
frontend/.vite
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ---- Node / server (Express + TS API; CONTRACT §9) --------------------------
# `**/node_modules` above already matches, but the contract requires these two
# explicitly: local dependency trees and tsc output never enter the context —
# the multi-stage Dockerfile runs `npm ci` and `npm run build` itself.
server/node_modules
server/dist

# ---- Rust / legacy backend (v1 — kept for reference, no longer built) -------
backend/target
**/target

# ---- Python / ingestion -----------------------------------------------------
**/__pycache__
**/*.pyc
**/*.pyo
**/.pytest_cache
**/.mypy_cache
**/.venv
**/venv

# ---- Editor / OS cruft ------------------------------------------------------
.vscode
.idea
**/.DS_Store
*.swp

# ---- Docs & meta not needed at build time -----------------------------------
**/*.md
docs
.dockerignore
docker-compose.yml
Dockerfile
**/Dockerfile
