# =============================================================================
# The Almanac Cup — World Cup 2026 — environment template (CONTRACT §8).
#
# Copy to `.env` (`cp .env.example .env`) before `docker compose up --build`.
# Variable NAMES are fixed by the contract — do not rename them. The values
# below are safe local-development defaults; override per deployment.
# Durations are metric SI seconds.
#
# v2 note: APP_BIND_ADDR and RUST_LOG are RETIRED (the Rust backend is legacy);
# the Node/Express server reads PORT, APP_SECRET and ADMIN_USERNAMES instead.
# =============================================================================

# Postgres DSN used by BOTH the backend and the ingest service. Host `db` is the
# compose service name; credentials match the db service (wc / wc / worldcup).
DATABASE_URL=postgres://wc:wc@db:5432/worldcup

# TCP port the Node/Express server binds inside its container (the compose file
# publishes it as host port 8080 as well).
PORT=8080

# JWT signing secret (HS256, 90-day tokens). This is a PLACEHOLDER — change it
# to a long random string before any real deployment; anyone who knows it can
# mint valid tokens.
APP_SECRET=change-me-please

# Comma-separated usernames granted is_admin = true on every login
# (passwordless auth: logging in with a listed name IS the admin setup).
ADMIN_USERNAMES=tom

# Build-TIME API base inlined into the frontend bundle by Vite. `/api` is
# same-origin: the nginx container proxies /api/ → backend:8080, so a Raspberry
# Pi deployment can leave this as-is. Only set an absolute origin (e.g.
# http://<pi-ip>:8080/api) if the API is exposed separately from the SPA.
VITE_API_BASE=/api

# Optional upstream fixtures feed for the Python ingestion (blank → idle/mock).
FIXTURE_FEED_URL=

# Cadence of the ingestion loop, in metric SI seconds (300 s = 5 min).
INGEST_INTERVAL_SECS=300
