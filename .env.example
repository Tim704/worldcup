# =============================================================================
# World Cup 2026 Fantasy Hub — environment template (CONTRACT §9).
#
# Copy to `.env` (`cp .env.example .env`) before `docker compose up --build`.
# Variable NAMES are fixed by the contract — do not rename them. The values
# below are safe local-development defaults; override per deployment.
# Durations are metric SI seconds.
# =============================================================================

# Postgres DSN used by BOTH the backend and the ingest service. Host `db` is the
# compose service name; credentials match the db service (wc / wc / worldcup).
DATABASE_URL=postgres://wc:wc@db:5432/worldcup

# Socket the Axum backend binds to inside its container (host:port form).
APP_BIND_ADDR=0.0.0.0:8080

# tracing/env-filter log directive for the backend (module=level, comma-list).
RUST_LOG=info,worldcup_hub=debug

# Build-TIME API base URL inlined into the frontend bundle by Vite (browser-side
# origin of the API; points at the host-exposed backend by default).
VITE_API_BASE=http://localhost:8080/api

# Optional upstream fixtures feed for the Python ingestion (blank → idle/mock).
FIXTURE_FEED_URL=

# Cadence of the ingestion loop, in metric SI seconds (300 s = 5 min).
INGEST_INTERVAL_SECS=300
