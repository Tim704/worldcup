{
  "name": "almanac-cup-server",
  "version": "2.0.0",
  "private": true,
  "description": "The Almanac Cup — World Cup 2026 API. Node/Express + TypeScript + PostgreSQL (Contract v2).",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "test": "tsx --test src/lib/scoring.test.ts src/lib/wagers.test.ts"
  },
  "dependencies": {
    "express": "^4.19.2",
    "pg": "^8.12.0",
    "jsonwebtoken": "^9.0.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "tsx": "^4.19.0",
    "@types/node": "^22",
    "@types/express": "^4.17.21",
    "@types/pg": "^8.11.6",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/cors": "^2.8.17"
  }
}
